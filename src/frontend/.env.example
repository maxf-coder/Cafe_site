# Backend API URL (Vite bakes this into the bundle at build time)
VITE_API_URL=http://localhost:8000/api/v1/

# Canonical site URL for SEO (rendered in meta tags/rel=canonical). 
# Leave empty in dev — falls back to window.location.origin.
# In production, set this to your custom domain, e.g. https://www.yourdomain.com
VITE_SITE_URL=