# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY="your-secret-key-here"

# PostgreSQL connection - the first 3 variables are overwrited from the global env when you use docker-compose
DATABASE_NAME=cafe_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Set "True" for debug mode (dev only, never in production)
DEBUG=False

# Comma-separated allowed host/domain names — includes Render/ production domain
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Comma-separated frontend origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# Comma-separated trusted origins for CSRF (the backend's own URL)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,https://your-backend-domain.com

# Cloudflare R2 credentials — create bucket at https://dash.cloudflare.com → R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cafe-media
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=https://<public-bucket-domain>.r2.dev